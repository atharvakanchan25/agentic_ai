# Environment Configuration for University Timetable Management System

# Database Configuration
DATABASE_URL=sqlite:///./timetable.db
DATABASE_ECHO=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Frontend Configuration
FRONTEND_PORT=5173
FRONTEND_HOST=localhost

# MCP Server Configuration
MCP_HOST=localhost
MCP_PORT=8765
MCP_ENABLED=true

# Timetable Generation Settings
MAX_HOURS_PER_DAY=8
WORKING_DAYS=Monday,Tuesday,Wednesday,Thursday,Friday
LUNCH_BREAK_SLOT=4
SOLVER_TIMEOUT_SECONDS=30

# Constraint Settings
MIN_ROOM_CAPACITY_BUFFER=5
MAX_CONSECUTIVE_CLASSES=3

# Agent Settings
AGENT_TIMEOUT=60
MAX_RETRIES=3

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/timetable.log

# Security (for production)
SECRET_KEY=your-secret-key-here
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173